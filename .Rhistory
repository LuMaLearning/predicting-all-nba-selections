p_direction(fit_refined)
# 1. Fetch data from Basketball Reference
# include_all_nba = TRUE adds the selection status automatically
raw_data <- bref_players_stats(seasons = 2024,
tables = c("totals", "advanced"),
include_all_nba = TRUE)
raw_data <- bref_players_stats(seasons = 2023,
tables = c("totals", "advanced"),
include_all_nba = TRUE)
# Increase the connection buffer size
Sys.setenv("VROOM_CONNECTION_SIZE" = 131072 * 5)
# Clear your session's memory to ensure a fresh scrape
gc()
# 1. Fetch data from Basketball Reference
raw_data <- bref_players_stats(seasons = 2023,
tables = c("totals", "advanced"),
include_all_nba = TRUE)
# 1. Fetch data from Basketball Reference
test_totals <- bref_players_stats(seasons = 2024, tables = "totals")
test_advanced <- bref_players_stats(seasons = 2024, tables = "advanced")
# 1. Fetch data from Basketball Reference (Split to avoid index errors)
season <- 2023
# We use 'possibly' to make the calls more resilient
safe_bref <- possibly(bref_players_stats, otherwise = NULL)
test_totals <- safe_bref(seasons = season, tables = "totals")
test_advanced <- safe_bref(seasons = season, tables = "advanced")
# 2. Clean and calculate ratioWS
# We join the two tables together before filtering and mutating
nba_stats <- test_totals %>%
inner_join(test_advanced %>% select(slugPlayer, ratioWinShares, numberAllNBATeam),
by = "slugPlayer") %>%
# Filter for players with significant minutes to avoid noise
filter(minutesTotals > 100) %>%
mutate(
# Create ratioWS from the advanced table
ratioWS = ratioWinShares,
# Handle the All-NBA logic (Binary 1/0)
is_all_nba = ifelse(!is.na(numberAllNBATeam), 1, 0)
) %>%
select(
namePlayer,
is_all_nba,
ratioWS,
G = countGames,
PTS = ptsTotals,
MP = minutesTotals,
BLK = blkTotals,
STL = stlTotals,
PF = pfTotals
) %>%
# Ensure we only have one row per player (handles mid-season trades)
group_by(namePlayer) %>%
filter(row_number() == 1) %>%
ungroup()
