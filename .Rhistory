p90    = ~quantile(.x, 0.90, na.rm = TRUE)
)
)
) %>%
pivot_longer(
everything(),
names_to = c("variable", ".value"),
names_sep = "_"
)
summary_tbl <- player_df %>%
select(-is_all_nba) |>
summarise(
across(
where(is.numeric),
list(
mean   = ~mean(.x, na.rm = TRUE),
sd     = ~sd(.x, na.rm = TRUE),
median = ~median(.x, na.rm = TRUE),
p90    = ~quantile(.x, 0.90, na.rm = TRUE)
)
)
) %>%
pivot_longer(
everything(),
names_to = c("variable", ".value"),
names_sep = "_"
)
kable(summary_tbl)
