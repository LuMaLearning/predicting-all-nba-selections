install.packages("car")
car::vif(glm(
is_all_nba ~ ratioWS + G + MP + FG + FGA + `3P` + FT + FTA + TRB + AST + STL + BLK + TOV + PF + PTS,
data = player_df,
family = binomial()
))
x <- model.matrix(
is_all_nba ~ ratioWS + G + MP + FG + FGA + `3P` + FT + FTA + TRB + AST + STL + BLK + TOV + PF + PTS,
data = player_df
)[, -1]
y <- player_df$is_all_nba
cv <- cv.glmnet(x, y, family = "binomial", alpha = 1)  # alpha=0 ridge, alpha=1 lasso
fit <- glmnet(x, y, family = "binomial", lambda = cv$lambda.min, alpha = 1)
coef(fit)
# install.packages("brms")
library(brms)
hs_prior <- prior(horseshoe(df = 1), class = "b")  # shrinkage on all slopes
fit_hs <- brm(
is_all_nba ~ ratioWS + G + MP + FG + FGA + `3P` + FT + FTA +
TRB + AST + STL + BLK + TOV + PF + PTS,
data = player_df,
family = bernoulli(link = "logit"),
prior = hs_prior,
chains = 4, cores = 4, iter = 2000,
control = list(adapt_delta = 0.95)
)
# install.packages("brms")
library(brms)
hs_prior <- prior(horseshoe(df = 1), class = "b")  # shrinkage on all slopes
fit_hs <- brm(
is_all_nba ~ ratioWS + G + MP + FG + FGA + FT + FTA +
TRB + AST + STL + BLK + TOV + PF + PTS,
data = player_df,
family = bernoulli(link = "logit"),
prior = hs_prior,
chains = 4, cores = 4, iter = 2000,
control = list(adapt_delta = 0.95)
)
summary(fit_hs)
library(projpred)
install.packages("projpred")
library(projpred)
# Perform variable selection
cv_select <- cv_varsel(fit_hs, method = 'forward', cv_method = 'LOO')
# Visualize the trade-off
plot(cv_select, stats = c('elpd', 'rmse'))
# install.packages("brms")
library(brms)
hs_prior <- prior(horseshoe(df = 1), class = "b")  # shrinkage on all slopes
# normalize all var.
player_df_scaled <- player_df %>%
mutate(across(c(ratioWS, G, MP, FG, FGA, FT, FTA, TRB, AST, STL, BLK, TOV, PF, PTS), scale))
fit_hs <- brm(
is_all_nba ~ ratioWS + G + MP + FG + FGA + FT + FTA +
TRB + AST + STL + BLK + TOV + PF + PTS,
data = player_df_scaled,
family = bernoulli(link = "logit"),
prior = hs_prior,
chains = 4, cores = 4, iter = 2000,
control = list(adapt_delta = 0.95)
)
summary(fit_hs)
install.packages("bayestestR")
library(bayestestR)
# Calculate the probability that the effect is non-zero
pd_results <- p_direction(fit_hs)
print(pd_results)
fit_refined <- brm(
is_all_nba ~ ratioWS + G + PTS + MP + BLK + STL + PF,
data = player_df_scaled,
family = bernoulli(link = "logit"),
prior = hs_prior,
chains = 4, iter = 2000
)
# Then check pd again
p_direction(fit_refined)
# Generate predicted probabilities for every player in your data
preds <- posterior_epred(fit_refined)
# Calculate the average probability for each player
player_df$prob_all_nba <- colMeans(preds)
# Create the ranking
player_ranks <- player_df %>%
arrange(desc(prob_all_nba)) %>%
mutate(predicted_rank = row_number()) %>%
select(predicted_rank, prob_all_nba, everything())
# View the top 15 predicted All-NBA players
head(player_ranks, 15)
gc()
